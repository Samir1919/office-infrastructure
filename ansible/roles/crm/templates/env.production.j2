NODE_ENV=production
PORT={{ crm_port }}
MONGO_URI=mongodb://{{ crm_database_user }}:{{ vault_mongodb_crm_password | urlencode }}@{{ crm_database_host }}:{{ crm_database_port }}/{{ crm_database_name }}?authSource={{ crm_database_name }}
SESSION_SECRET={{ vault_crm_session_secret }}
# The internal canary is intentionally HTTP-only. Public HTTPS deployment keeps this true/default.
SESSION_COOKIE_SECURE=false
ADMIN_EMAIL={{ crm_bootstrap_admin_email }}
ADMIN_PASSWORD={{ vault_crm_admin_password }}
ADMIN_NAME={{ crm_bootstrap_admin_name }}
